{
  "name": "youtube-downloader",
  "version": "1.0.0",
  "description": "YouTube Downloader Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.local.youtube-downloader",
    "productName": "YouTube Downloader",
    "mac": {
      "target": "dir",
      "category": "public.app-category.utilities"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__/**", "!*.pyc", "!.pytest_cache/**"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend-dist"
      }
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
